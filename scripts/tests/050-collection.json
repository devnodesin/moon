{
  "docURL": "http://localhost:6000",
  "serverURL": "http://localhost:6000",
  "prefix": "",
  "username": "admin",
  "password": "MoonAdmin12#",
  "health": "/health",
  "tests": [
    {
      "name": "Create Collection",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "details": "Create a new collection named `products` with typed columns.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {
            "name": "products",
            "columns": [
              {"name": "title",       "type": "string",  "nullable": false, "unique": true},
              {"name": "price",       "type": "integer", "nullable": false},
              {"name": "description", "type": "string",  "nullable": true},
              {"name": "category",    "type": "string",  "nullable": true}
            ]
          }
        ]
      }
    },
    {
      "name": "List Collections",
      "cmd": "GET",
      "endpoint": "/collections:query",
      "details": "Retrieve all user-defined collections.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Get Collection",
      "cmd": "GET",
      "endpoint": "/collections:query?name=products",
      "details": "Retrieve metadata for a specific collection.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Get Schema",
      "cmd": "GET",
      "endpoint": "/data/products:schema",
      "details": "Retrieve the field schema for the `products` collection.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Update Collection — Add Column",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "details": "Add a new `stock` column to the `products` collection.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "update",
        "data": [
          {
            "name": "products",
            "add_columns": [
              {"name": "stock", "type": "integer", "nullable": true}
            ]
          }
        ]
      }
    },
    {
      "name": "Update Collection — Rename Column",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "details": "Rename `description` to `details`.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "update",
        "data": [
          {
            "name": "products",
            "rename_columns": [
              {"old_name": "description", "new_name": "details"}
            ]
          }
        ]
      }
    },
    {
      "name": "Update Collection — Remove Column",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "details": "Remove the `category` column.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "update",
        "data": [
          {
            "name": "products",
            "remove_columns": ["category"]
          }
        ]
      }
    },
    {
      "name": "Delete Collection",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "details": "Permanently delete the `products` collection and all its data.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "destroy",
        "data": [{"name": "products"}]
      }
    }
  ]
}

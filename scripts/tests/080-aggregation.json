{
  "docURL": "http://localhost:6000",
  "serverURL": "https://moon.devnodes.in",
  "prefix": "",
  "username": "admin",
  "password": "MoonAdmin12#",
  "health": "/health",
  "tests": [
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {
            "name": "products",
            "columns": [
              {"name": "title",    "type": "string",  "nullable": false},
              {"name": "price",    "type": "integer", "nullable": false},
              {"name": "quantity", "type": "integer", "nullable": true},
              {"name": "brand",    "type": "string",  "nullable": true}
            ]
          }
        ]
      }
    },
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/data/products:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {"title": "Wireless Mouse",  "price": 29,  "quantity": 10, "brand": "Wow"},
          {"title": "USB Keyboard",    "price": 19,  "quantity": 55, "brand": "Orange"},
          {"title": "Monitor 21 inch", "price": 199, "quantity": 20, "brand": "Wow"}
        ]
      }
    },
    {
      "name": "List with Filters",
      "cmd": "GET",
      "endpoint": "/data/products:query?brand[eq]=Wow",
      "details": "Filter records where `brand` equals `Wow`.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "List with Sort",
      "cmd": "GET",
      "endpoint": "/data/products:query?sort=-quantity",
      "details": "Sort records by `quantity` in descending order.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "List All Records",
      "cmd": "GET",
      "endpoint": "/data/products:query",
      "details": "Retrieve all records from the collection.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "destroy",
        "data": [{"name": "products"}]
      }
    }
  ]
}

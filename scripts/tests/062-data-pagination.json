{
  "docURL": "http://localhost:6000",
  "serverURL": "https://moon.devnodes.in",
  "prefix": "",
  "username": "admin",
  "password": "MoonAdmin12#",
  "health": "/health",
  "tests": [
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {
            "name": "products",
            "columns": [
              {"name": "title",    "type": "string",  "nullable": false},
              {"name": "quantity", "type": "integer", "nullable": true}
            ]
          }
        ]
      }
    },
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/data/products:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {"title": "Product 1", "quantity": 1},
          {"title": "Product 2", "quantity": 2},
          {"title": "Product 3", "quantity": 3},
          {"title": "Product 4", "quantity": 4},
          {"title": "Product 5", "quantity": 5},
          {"title": "Product 6", "quantity": 6},
          {"title": "Product 7", "quantity": 7}
        ]
      }
    },
    {
      "name": "First Page",
      "cmd": "GET",
      "endpoint": "/data/products:query?per_page=3&page=1",
      "details": "Retrieve the first page (3 records per page). The response includes `meta` with pagination info and `links` for navigation.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Second Page",
      "cmd": "GET",
      "endpoint": "/data/products:query?per_page=3&page=2",
      "details": "Retrieve the second page.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Last Page",
      "cmd": "GET",
      "endpoint": "/data/products:query?per_page=3&page=3",
      "details": "Retrieve the last (third) page. Only one record is returned.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "destroy",
        "data": [{"name": "products"}]
      }
    }
  ]
}

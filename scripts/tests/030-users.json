{
  "docURL": "http://localhost:6000",
  "serverURL": "https://moon.devnodes.in",
  "prefix": "",
  "username": "admin",
  "password": "MoonAdmin12#",
  "health": "/health",
  "tests": [
    {
      "name": "Create User",
      "cmd": "POST",
      "endpoint": "/data/users:mutate",
      "details": "Create a new user account.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {
            "username": "moonuser",
            "email": "moonuser@example.com",
            "password": "UserPass123#",
            "role": "user",
            "can_write": false
          }
        ]
      }
    },
    {
      "name": "List All Users",
      "cmd": "GET",
      "endpoint": "/data/users:query",
      "details": "Retrieve all users.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Get User by ID",
      "cmd": "GET",
      "endpoint": "/data/users:query?id=$ULID",
      "details": "Retrieve a specific user by their ULID.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Update User",
      "cmd": "POST",
      "endpoint": "/data/users:mutate",
      "details": "Update an existing user's fields.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "update",
        "data": [
          {
            "id": "$ULID",
            "email": "moonuser_updated@example.com"
          }
        ]
      }
    },
    {
      "name": "Delete User",
      "cmd": "POST",
      "endpoint": "/data/users:mutate",
      "details": "Delete a user account.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "destroy",
        "data": [{"id": "$ULID"}]
      }
    }
  ]
}

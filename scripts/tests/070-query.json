{
  "docURL": "http://localhost:6000",
  "serverURL": "https://moon.devnodes.in/api",
  "prefix": "",
  "username": "admin",
  "password": "MoonAdmin12#",
  "health": "/health",
  "tests": [
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {
            "name": "products",
            "columns": [
              {"name": "title",    "type": "string",  "nullable": false},
              {"name": "price",    "type": "integer", "nullable": false},
              {"name": "details",  "type": "string",  "nullable": true},
              {"name": "quantity", "type": "integer", "nullable": true},
              {"name": "brand",    "type": "string",  "nullable": true}
            ]
          }
        ]
      }
    },
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/data/products:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "create",
        "data": [
          {"title": "Wireless Mouse",  "price": 29,  "details": "Ergonomic wireless mouse", "quantity": 10, "brand": "Wow"},
          {"title": "USB Keyboard",    "price": 19,  "details": "Gaming keyboard",          "quantity": 55, "brand": "Orange"},
          {"title": "Monitor 21 inch", "price": 199, "details": "Full HD monitor",          "quantity": 20, "brand": "Wow"},
          {"title": "Laptop Stand",    "price": 49,  "details": "Adjustable laptop stand",  "quantity":  8, "brand": "Wow"},
          {"title": "Webcam HD",       "price": 79,  "details": "1080p webcam",             "quantity":  3, "brand": "Orange"}
        ]
      }
    },
    {
      "name": "Filtering",
      "cmd": "GET",
      "details": "Filter results using `?{field}[op]=value`. Supported operators: `eq`, `ne`, `gt`, `lt`, `gte`, `lte`, `like`, `in`.",
      "endpoint": "/data/products:query?quantity[gt]=5&brand[eq]=Wow",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Sorting",
      "cmd": "GET",
      "details": "Use `?sort={field1,-field2}` to sort. Prefix with `-` for descending. Multiple fields are comma-separated.",
      "endpoint": "/data/products:query?sort=-quantity,title",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Full-Text Search",
      "cmd": "GET",
      "details": "Use `?q={term}` to search across all string fields.",
      "endpoint": "/data/products:query?q=mouse",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Field Selection",
      "cmd": "GET",
      "details": "Use `?fields={field1,field2}` to return only the specified columns (`id` is always included).",
      "endpoint": "/data/products:query?fields=quantity,title",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Pagination",
      "cmd": "GET",
      "details": "Use `?per_page={n}&page={p}` to paginate. Default `per_page` is 15; maximum is 200.",
      "endpoint": "/data/products:query?per_page=2&page=1",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Combined Query Options",
      "cmd": "GET",
      "details": "Combine filtering, sorting, field selection, and pagination in one request.",
      "endpoint": "/data/products:query?brand[eq]=Wow&sort=-price&fields=title,price,quantity&per_page=10&page=1",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "",
      "cmd": "POST",
      "endpoint": "/collections:mutate",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "destroy",
        "data": [{"name": "products"}]
      }
    }
  ]
}

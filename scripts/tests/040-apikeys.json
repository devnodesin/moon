{
  "docURL": "http://localhost:6000",
  "serverURL": "https://moon.devnodes.in",
  "prefix": "",
  "username": "admin",
  "password": "MoonAdmin12#",
  "health": "/health",
  "tests": [
    {
      "name": "Create API Key",
      "cmd": "POST",
      "endpoint": "/data/apikeys:mutate",
      "details": "Create a new API key.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
        "data": {
          "op": "create",
          "data": [
            {
              "name": "Integration Service",
              "role": "user",
              "can_write": false,
              "is_website": true,
              "allowed_origins": [
                "https://moon.devnodes.in"
              ],
              "rate_limit": 5,
              "captcha_required": true,
              "enabled": true
            }
          ]
        }
    },
    {
      "name": "List API Keys",
      "cmd": "GET",
      "endpoint": "/data/apikeys:query",
      "details": "Retrieve all API keys.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Get API Key by ID",
      "cmd": "GET",
      "endpoint": "/data/apikeys:query?id=$ULID",
      "details": "Retrieve a specific API key by its ULID.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN"
      }
    },
    {
      "name": "Update API Key Metadata",
      "cmd": "POST",
      "endpoint": "/data/apikeys:mutate",
      "details": "Update API key metadata (name, description) without changing the key itself.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
        "data": {
          "op": "update",
          "data": [
            {
              "id": "$ULID",
              "name": "Updated Integration Service",
              "allowed_origins": [
                "https://moon.devnodes.in",
                "https://www.moon.devnodes.in"
              ],
              "rate_limit": 10,
              "captcha_required": false,
              "enabled": true
            }
          ]
        }
    },
    {
      "name": "Rotate API Key",
      "cmd": "POST",
      "endpoint": "/data/apikeys:mutate",
      "details": "Generate a new key value and invalidate the old one in a single step.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "action",
        "action": "rotate",
        "data": [{"id": "$ULID"}]
      }
    },
    {
      "name": "Delete API Key",
      "cmd": "POST",
      "endpoint": "/data/apikeys:mutate",
      "details": "Permanently delete an API key.",
      "headers": {
        "Authorization": "Bearer $ACCESS_TOKEN",
        "Content-Type": "application/json"
      },
      "data": {
        "op": "destroy",
        "data": [{"id": "$ULID"}]
      }
    }
  ]
}
